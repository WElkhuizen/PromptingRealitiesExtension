{
  "type": "object",
  "required": ["answer", "MQTT_value"],
  "properties": {
    "answer": {
      "type": "string"
    },
    "MQTT_value": {
      "type": "object",
      "required": ["rules", "default_actions"],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "priority", "condition_logic", "checks", "actions"],
            "properties": {
              "label":           { "type": "string" },
              "priority":        { "type": "integer" },
              "condition_logic": { "type": "string", "enum": ["AND", "OR"] },
              "checks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["input", "op", "value"],
                  "properties": {
                    "input": { "type": "string" },
                    "op":    { "type": "string", "enum": ["<", ">", "<=", ">=", "==", "!="] },
                    "value": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["output", "values"],
                  "properties": {
                    "output": { "type": "string" },
                    "values": { "type": "array", "items": { "type": "number" } }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "default_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["output", "values"],
            "properties": {
              "output": { "type": "string" },
              "values": { "type": "array", "items": { "type": "number" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
